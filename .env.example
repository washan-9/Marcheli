# Configuración de Base de Datos PostgreSQL
DB_NAME=marcheli_db
DB_USER=admin
DB_PASSWORD=password123
DB_PORT=5432

# Configuración de Base de Datos MongoDB
MONGO_USER=admin
MONGO_PASSWORD=password123
MONGO_PORT=27017

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth Config
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Restricción de dominio institucional (solo correos @unmsm.edu.pe)
ALLOWED_EMAIL_DOMAIN=unmsm.edu.pe

# Database (URL para Prisma)
DATABASE_URL="postgresql://admin:password123@localhost:5432/marcheli_db?schema=public"

# MongoDB (URI para Mongoose en apps/api)
MONGODB_URI="mongodb://admin:password123@localhost:27017/marcheli_nosql?authSource=admin"

# Microservicio de IA (Sentinel)
SENTINEL_URL=http://localhost:8000
ANTHROPIC_API_KEY=
