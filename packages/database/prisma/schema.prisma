// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SPECIALIST // Psicólogo
  STUDENT    // Estudiante
}

// ---------------------------------------------------------------------------
// Autenticación (NextAuth) — gestionada vía @marcheli/auth
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  accounts      Account[]
  sessions      Session[]

  // Perfil del estudiante y asignación de psicólogo
  studentProfile   StudentProfile?
  assignedStudents StudentProfile[] @relation("AssignedSpecialist")

  // Citas (telemedicina)
  appointmentsAsSpecialist Appointment[] @relation("SpecialistAppointments")
  appointmentsAsStudent    Appointment[] @relation("StudentAppointments")

  // Registro de ánimo diario (Pantalla 2)
  moodLogs MoodLog[]

  // Notas de sesión del psicólogo (panel web)
  notesAsPsychologist SessionNote[] @relation("PsychologistNotes")
  notesAsStudent      SessionNote[] @relation("StudentNotes")

  // Alertas de triaje / semáforo de riesgo
  triages Triage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Dominio clínico
// ---------------------------------------------------------------------------

model StudentProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedSpecialistId String?
  specialist           User?    @relation("AssignedSpecialist", fields: [assignedSpecialistId], references: [id])
  studentCode          String? // Código de matrícula UNMSM
  faculty              String? // Facultad / Escuela
  age                  Int?
  medicalHistory       String?  @db.Text
  emergencyContact     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Registro de ánimo diario — 5 niveles, base del gráfico de 7 días y del semáforo
model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      Mood
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum Mood {
  MUY_MAL
  MAL
  REGULAR
  BIEN
  MUY_BIEN
}

// Citas / Telemedicina (Pantalla 4)
model Appointment {
  id           String            @id @default(cuid())
  studentId    String
  specialistId String
  student      User              @relation("StudentAppointments", fields: [studentId], references: [id])
  specialist   User              @relation("SpecialistAppointments", fields: [specialistId], references: [id])
  scheduledAt  DateTime
  status       AppointmentStatus @default(SCHEDULED)
  notes        String?           @db.Text
  meetingLink  String? // URL WebRTC
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// Notas privadas de sesión escritas por el psicólogo (panel web)
model SessionNote {
  id             String   @id @default(cuid())
  studentId      String
  psychologistId String
  appointmentId  String?
  student        User     @relation("StudentNotes", fields: [studentId], references: [id])
  psychologist   User     @relation("PsychologistNotes", fields: [psychologistId], references: [id])
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([studentId])
}

// Alerta de triaje / semáforo — generada por chat, ánimo, encuesta o manual
model Triage {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  riskLevel    RiskLevel    @default(LOW)
  source       TriageSource @default(MANUAL)
  acknowledged Boolean      @default(false)
  notes        String?      @db.Text
  detectedAt   DateTime     @default(now())

  @@index([userId])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TriageSource {
  CHAT
  MOOD
  QUESTIONNAIRE
  MANUAL
}
